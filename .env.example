# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:port/database

# Or individual PostgreSQL params
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=gupi
# PGUSER=postgres
# PGPASSWORD=postgres

# Set to 'true' to force SSL connection (Railway requires this)
PGSSL=true

# JWT secret for admin authentication
JWT_SECRET=gupi-secret-key-2026

# Node environment
NODE_ENV=production
